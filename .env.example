# 插件参数、消息审查等配置：登录 Web 控制台后编辑，或查阅文档后手动追加键值。
# 文档索引：docs/plugins/README.md ；常见问题：docs/FAQ.md ；标准部署：docs/Deployment.md

# ---- NoneBot / 调度 ----
APSCHEDULER_AUTOSTART=false
COMMAND_START=["","/"]
# 超管 QQ（JSON 数组，整数）
SUPERUSERS=[""]

# ---- OneBot 反向 WS / HTTP 监听（协议端填写的 WS URL 端口须与此一致）----
HOST=0.0.0.0
PORT=8088
ACCESS_TOKEN=

# ---- 数据后端：mongodb 或 postgresql（使用 PG 前需 uv sync --extra pg）----
DB_BACKEND=mongodb

MONGO_HOST=127.0.0.1
MONGO_PORT=27017
MONGO_USER=
MONGO_PASSWORD=
# MONGO_DB=PallasBot

# PostgreSQL（DB_BACKEND=postgresql 时取消注释并填写）
# PG_HOST=127.0.0.1
# PG_PORT=5432
# PG_USER=
# PG_PASSWORD=
# PG_DB=PallasBot

# 连接池参数（默认 10 常驻 + 20 弹性 + 1800 秒空闲回收）
# 小规模部署可维持默认；QPS 高或并发群数多时可适度调大 pool_size / max_overflow
#PG_POOL_SIZE=10
#PG_MAX_OVERFLOW=20
#PG_POOL_RECYCLE=1800

# 是否启用被踢自动拉黑功能
#ENABLE_KICK_BAN=false

# pallas_webui 开发模式，仅限本机开发时使用
PALLAS_WEBUI_DEV_MODE=false

# sing 功能相关配置

# key 对应命令词，即“牛牛唱歌” or “兔兔唱歌”
# value 对应 AI Server 端 resource/sing/models/ 下的文件夹名，以及生成的音频文件名，也要对应模型 config 文件里的 spk 字段
# 注意 .env 里 dict 不能换行哦，得在一行写完所有的
SING_SPEAKERS={"帕拉斯": "pallas", "牛牛": "pallas"}

# 每次合成并发送的语音长度，单位：秒
SING_LENGTH=60

# AI Server 配置

# AI Server HOST
AI_SERVER_HOST=127.0.0.1

# AI Server port
AI_SERVER_PORT=9099

# 是否启用 Sing 功能
SING_ENABLE=false

# 是否启用 Chat 功能
CHAT_ENABLE=false

# 是否启用 TTS 功能
TTS_ENABLE=false

# AI Server 超时时间
# 注意 AI SERVER 会立即返回 task_id 并使用回调方式返回结果，超时时间无需设置太长
#AI_SEVER_TIMEOUT=10

# 重试次数
#AI_SERVER_RETRY=3

# 好友/入群通知是否同时发送给SUPERUSERS
#REQUEST_HANDLER_NOTIFY_SUPERUSERS=false  # 不发送（默认发送给牛牛的admins）
