APSCHEDULER_AUTOSTART=false
COMMAND_START=["","/"]
SUPERUSERS=[""]

HOST=0.0.0.0
PORT=8088
ACCESS_TOKEN=

# 数据库后端选择：mongodb（默认）或 postgresql。
# postgresql 启用前需先执行：uv sync --extra pg
# 若使用 postgresql，请填写PG_USER 和 PG_PASSWORD
DB_BACKEND=mongodb

# mongodb 相关配置，请勿注释，如无特殊需求无需更改

MONGO_HOST=127.0.0.1
MONGO_PORT=27017
# 请勿注释，如需认证可填写以下两项
MONGO_USER=
MONGO_PASSWORD=
#MONGO_DB=PallasBot

# postgresql 相关配置
# 启用前需：uv sync --extra pg 安装 sqlalchemy + asyncpg
# 若未设置 PG_HOST，会 fallback 使用 MONGO_HOST（仅适合同机部署，否则请显式填写）
#PG_HOST=127.0.0.1
#PG_PORT=5432
#PG_USER=
#PG_PASSWORD=
# PostgreSQL 数据库名，默认 PallasBot；不存在时会自动创建
# 仅允许字母/数字/下划线/连字符，避免 CREATE DATABASE 注入
#PG_DB=PallasBot

# 连接池参数（默认 10 常驻 + 20 弹性 + 1800 秒空闲回收）
# 小规模部署可维持默认；QPS 高或并发群数多时可适度调大 pool_size / max_overflow
#PG_POOL_SIZE=10
#PG_MAX_OVERFLOW=20
#PG_POOL_RECYCLE=1800


# 以下配置项均有默认值，保持注释即使用默认值

# 是否启用被踢自动拉黑功能
#ENABLE_KICK_BAN=false


# 复读机功能相关参数，推荐保持注释

# answer 相关阈值，值越大，牛牛废话越少；越小，牛牛废话越多
#ANSWER_THRESHOLD=3

# answer 阈值权重
#ANSWER_THRESHOLD_WEIGHTS=[7, 23, 70]

# 上下文联想，记录多少个关键词（每个群）
#TOPICS_SIZE=16

# 上下文命中后，额外的权重系数
#TOPICS_IMPORTANCE=10000

# N 个群有相同的回复，就跨群作为全局回复
#CROSS_GROUP_THRESHOLD=2

# 复读的阈值，群里连续多少次有相同的发言，就复读
#REPEAT_THRESHOLD=3

# 复读判定与学习均忽略的第三方 QQ，如 [123456789,987654321]；
#REPEAT_IGNORE_USER_IDS=

# 主动发言的阈值，越小废话越多
#SPEAK_THRESHOLD=5

# 说过的话，接下来多少次不再说
#DUPLICATE_REPLY=10

# 按逗号分割回复语的概率
#SPLIT_PROBABILITY=0.5

# 喝醉之后，超过多长的文本全部转换成语音发送，仅当配置了 tts 时有效
#DRUNK_TTS_THRESHOLD=6

# 连续主动说话的概率
#SPEAK_CONTINUOUSLY_PROBABILITY=0.5

# 主动说话加上随机戳一戳群友的概率
#SPEAK_POKE_PROBABILITY=0.6

# 连续主动说话最多几句话
#SPEAK_CONTINUOUSLY_MAX_LEN=2

# 每隔多久进行一次持久化（秒）
#SAVE_TIME_THRESHOLD=3600

# 单个群超过多少条聊天记录就进行一次持久化，与时间是或的关系
#SAVE_COUNT_THRESHOLD=1000

# 保存时，给内存中保留的大小
#SAVE_RESERVED_SIZE=100

# 启用表情回应功能
#ENABLE_REACTION=True

# 启用日常消息一定概率触发表情回应
#ENABLE_PROBABILITY_REACTION=True

# 触发表情回应的概率
#REACTION_PROBABILITY=0.1

# 当收到含表情的消息时，自动回应
#ENABLE_FACE_REACTION=False

# 有人用表情回应任意消息时，牛牛跟着回应
#ENABLE_AUTO_REPLY_ON_REACTION=True

# 是否回应相同的表情
#REPLY_WITH_SAME_EMOJI=True

# sing 功能相关配置

# key 对应命令词，即“牛牛唱歌” or “兔兔唱歌”
# value 对应 AI Server 端 resource/sing/models/ 下的文件夹名，以及生成的音频文件名，也要对应模型 config 文件里的 spk 字段
# 注意 .env 里 dict 不能换行哦，得在一行写完所有的
SING_SPEAKERS={"帕拉斯": "pallas", "牛牛": "pallas"}

# 每次合成并发送的语音长度，单位：秒
SING_LENGTH=60



# AI Server 配置

# AI Server HOST
AI_SERVER_HOST=127.0.0.1

# AI Server port
AI_SERVER_PORT=9099

# 是否启用 Sing 功能
SING_ENABLE=false

# 是否启用 Chat 功能
CHAT_ENABLE=false

# 是否启用 TTS 功能
TTS_ENABLE=false

# AI Server 超时时间
# 注意 AI SERVER 会立即返回 task_id 并使用回调方式返回结果，超时时间无需设置太长
#AI_SEVER_TIMEOUT=10

# 重试次数
#AI_SERVER_RETRY=3

#bot_status 配置
# bot_status_smtp_user=your_email@example.com
# bot_status_smtp_password=your_email_password
# bot_status_smtp_server=smtp.example.com
# bot_status_smtp_port=465
# bot_status_notice_email=admin@example.com
#离线等待时长
# bot_status_offline_grace_time=30

#help 配置
# 默认使用的样式名称
# 可选值包括:
# - "default" - 库自带默认样式
# - "unicorn_sugar" - 独角兽Sugar风格，可爱系
# - "simple_beige" - 朴素米黄风格
# - "retro" - 最朴素的复古风格
# - 自定义的样式名称（在custom_styles中定义）

#DEFAULT_STYLE=pallas_default

# 自定义样式配置列表
# 在resource目录下新建一个custom文件夹，放置你的自定义样式目录，如: resource/custom/custom_style_name
# 路径应指向包含elements.json/yml和setting.json/yml的目录
# 参考https://github.com/Monody-S/CustomMarkdownImage
#CUSTOM_STYLES=[]

# 忽略的插件列表
#IGNORED_PLUGINS=["nonebot-plugin-alconna","nonebot_plugin_apscheduler","callback","block","greeting","bot_status"]

# 好友/入群通知是否同时发送给SUPERUSERS 
#REQUEST_HANDLER_NOTIFY_SUPERUSERS=false  # 不发送（默认发送给牛牛的admins）

# pallas_protocol：见 docs/plugins/pallas_protocol/README.md
#PALLAS_PROTOCOL_ENABLED=true
#PALLAS_PROTOCOL_WEBUI_ENABLED=true

# 在 https://github.com/settings/tokens 生成，生命周期设置 <= 366 天
#PALLAS_PROTOCOL_GITHUB_TOKEN=

# OneBot WS 连接配置（可以直链模式：PALLAS_PROTOCOL_ONEBOT_WS_URL=）
#PALLAS_PROTOCOL_ONEBOT_WS_HOST=127.0.0.1
#PALLAS_PROTOCOL_ONEBOT_WS_PORT=8088
#PALLAS_PROTOCOL_ONEBOT_WS_PATH=/onebot/v11/ws

# 启动时若未检测到运行时则自动后台下载
#PALLAS_PROTOCOL_AUTO_DOWNLOAD_RUNTIME=false

# pallas_webui 开发模式，仅限本机开发时使用
PALLAS_WEBUI_DEV_MODE=false

# 牛牛画画,配置含义见/docs/plugins/pallas_image/README.md
# PALLAS_IMAGE_MIN_PRIORITY=5
PALLAS_IMAGE_BASE_URL=
PALLAS_IMAGE_API_KEY=
PALLAS_IMAGE_MODEL=gpt-image-2
# PALLAS_IMAGE_SIZE=
# PALLAS_IMAGE_ASPECT_RATIO=
PALLAS_IMAGE_DRAW_COMMAND_COOLDOWN=3
# PALLAS_IMAGE_DRAW_GROUP_WHITELIST=[]
# PALLAS_IMAGE_DRAW_PER_USER_LIMIT=0
# 不计入「每日次数」的群 / QQ 号
# PALLAS_IMAGE_DRAW_UNLIMITED_GROUP_IDS=[]
# PALLAS_IMAGE_DRAW_UNLIMITED_USER_IDS=[]

# 牛牛做梦,配置含义见/docs/plugins/dream/README.md
# 未醉酒时：每发一轮梦话后随机睡多久再发下一轮（秒），最大值须 ≥ 最小值
DREAM_WORKER_SLEEP_MIN_SEC=45
DREAM_WORKER_SLEEP_MAX_SEC=165
# 历史梦只从最近多少天的消息里抽（至少 7）；调大池子更深、表更大
#DREAM_MESSAGE_RETENTION_DAYS=90
# 每个群单独记「最近发过哪些历史」条数，防同群短期内重复；0=不按历史键避让；进程不重启则跨多场累计
#DREAM_HISTORY_RECENT_DEDUPE_MAX=120
# 历史抽样多偏向新记录：0=均匀随机，越大越不爱抽老句
#DREAM_HISTORY_RECENCY_POWER=2.25
# 每轮有多大概率从他群漂流队列取一条实时梦话（0~1）
DREAM_DRIFT_QUEUE_TICK_PROBABILITY=0.8
# 本轮还能发图时，多大机会去抽归档画（0~1）
DREAM_ARCHIVE_IMAGE_PROBABILITY=0.5
# 从已学句 / 历史梦里换一条时最多重试几次
#DREAM_ECHO_RESAMPLE_ATTEMPTS=22
#DREAM_HIST_RESAMPLE_ATTEMPTS=12
# 未发实时漂流后：每 tick 多大概率先抽已学句再抽历史梦（0=永远先历史）
DREAM_PREFER_LEARNED_ECHO_PROBABILITY=0.2
