# 仅供 Docker Compose 插值（如 postgres 服务的 POSTGRES_*），与 config/pallas.toml 中 [bootstrap.postgres] 保持一致。
# 复制为 pallas-bot/config/compose.env 后：
#   docker compose --env-file ./pallas-bot/config/compose.env --profile postgres up -d
PG_USER=pallas
PG_PASSWORD=pallas
PG_DB=PallasBot
# Bot WebUI「AI 服务」Bearer Token 须与下方一致（注入 pallasbot-ai 的 PALLAS_AI_API_TOKEN）
# PALLAS_AI_API_TOKEN=
